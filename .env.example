# ═══════════════════════════════════════════════════════════
# DIRECTORYKIT — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]

# ── App ─────────────────────────────────────────────────────
# [REQUIRED] Your production URL (used for SEO, OG tags, emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [OPTIONAL] Set to "demo" to enable demo mode: visitors can access
# the admin panel and all pages without authentication.
# All write operations are blocked — changes won't persist to the database.
# NEXT_PUBLIC_APP_MODE=demo
# [OPTIONAL] Fallback URL for payment redirects (defaults to request host)
# NEXT_PUBLIC_URL=http://localhost:3000

# ── Supabase ────────────────────────────────────────────────
# [REQUIRED] From Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Prefer the new publishable key (sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# [REQUIRED] Server-side only — never expose to client!
# Prefer the new secret key (sb_secret_...)
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy JWT keys are still accepted if you're on an older project:
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
#   SUPABASE_SERVICE_ROLE_KEY=eyJ...
# [OPTIONAL] For `pnpm supabase:types` — regenerate TypeScript types from remote schema
# SUPABASE_PROJECT_ID=your-project-id

# ── Supabase Storage (S3-compatible) ────────────────────────
# [REQUIRED for file uploads] From Supabase Dashboard → Storage
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=your-s3-access-key
SUPABASE_S3_SECRET_ACCESS_KEY=your-s3-secret-key
SUPABASE_S3_BUCKET=storage

# ── Stripe Payments ─────────────────────────────────────────
# [REQUIRED for paid plans] From Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# [REQUIRED] Stripe Price IDs — create in Stripe Dashboard → Products
STRIPE_PRICE_ID_PREMIUM=price_...
# [OPTIONAL] Only if partner program is enabled
# STRIPE_PRICE_ID_PARTNER_SUBSCRIPTION=price_...
# [OPTIONAL] Promotion placement prices (monthly subscriptions)
# STRIPE_PRICE_ID_PROMO_BANNER=price_...
# STRIPE_PRICE_ID_PROMO_CATALOG=price_...
# STRIPE_PRICE_ID_PROMO_DETAIL=price_...
# [OPTIONAL] Stripe coupon ID for 30% discount when all 3 promo placements are selected
# Create in Stripe Dashboard → Coupons → Percentage off 30%, Duration: forever
# STRIPE_COUPON_ID_PROMO_ALL_THREE=

# ── Email (Resend) ──────────────────────────────────────────
# [REQUIRED] From https://resend.com/api-keys
RESEND_API_KEY=re_...
# [OPTIONAL] Override "From" address in production (e.g. "hello@yourdomain.com")
# RESEND_PRODUCTION_FROM=hello@yourdomain.com
# [OPTIONAL] Override "From" address in development (defaults to onboarding@resend.dev)
# RESEND_DEV_FROM=
# [OPTIONAL] Master override for "From" address (takes priority over all others)
# RESEND_FROM_EMAIL=
# [OPTIONAL] Redirect all dev emails to a single address for safety (defaults to 'true')
# RESEND_DEV_REDIRECT=true
# [OPTIONAL] Email address to redirect dev emails to
# RESEND_DEV_REDIRECT_TO=your-email@example.com

# ── SEO / Blog ──────────────────────────────────────────────
# [OPTIONAL] For AI-powered blog content via SEObot
# SEOBOT_API_KEY=

# ── Analytics ───────────────────────────────────────────────
# [OPTIONAL] Google Analytics 4 Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# [OPTIONAL] PostHog product analytics
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# [OPTIONAL] Google Search Console verification
# NEXT_PUBLIC_GOOGLE_VERIFICATION=

# ── Cron Jobs ───────────────────────────────────────────────
# [REQUIRED] Secret token to protect cron endpoints
CRON_SECRET=your-random-secret-string

# ── AI Features ──────────────────────────────────────────────
# [OPTIONAL] AI-powered description generation, category suggestions, SEO metadata
# Enable the 'ai' feature flag in config/features.config.ts to activate
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=


# ── External Integrations ──────────────────────────────────
# [OPTIONAL] Logo.dev — auto-fetch logos by domain when no logo is uploaded
# Get your publishable token at https://www.logo.dev
# NEXT_PUBLIC_LOGO_DEV_TOKEN=
# [OPTIONAL] ListingBott — external listing service link on pricing page
# NEXT_PUBLIC_LISTINGBOTT_URL=

# ── Build & Development ─────────────────────────────────────
# [OPTIONAL] Enable webpack bundle analyzer (run with ANALYZE=true pnpm build)
# ANALYZE=true
