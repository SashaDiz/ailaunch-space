{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/account-notifications",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/reverify-badges",
      "schedule": "0 4 * * 1"
    }
  ]
}
